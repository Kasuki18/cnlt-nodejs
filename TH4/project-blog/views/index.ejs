<link rel="stylesheet" href="/style.css">

<div class="container">
    <h1>🚀 Blog của tôi</h1>

    <a class="btn-add" href="/blogposts/new">+ Tạo bài viết</a>

    <div class="grid">
        <% posts.forEach(post => { %>
            <div class="card">
                <h3><%= post.title %></h3>
                <p><%= post.body %></p>

                <div class="actions">
                    <a class="view" href="/blogposts/<%= post._id %>">Chi tiết</a>
                    <a class="edit" href="/blogposts/edit/<%= post._id %>">Sửa</a>
                    <a class="delete" href="/blogposts/delete/<%= post._id %>">Xóa</a>
                </div>
            </div>
        <% }) %>
    </div>
</div>