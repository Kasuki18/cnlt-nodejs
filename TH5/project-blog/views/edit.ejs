<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Sửa bài viết</title>
</head>
<body>

<h1>Sửa bài viết</h1>

<form action="/blogposts/update/<%= post._id %>" method="POST">
    <p>Tiêu đề:</p>
    <input type="text" name="title" value="<%= post.title %>">

    <p>Nội dung:</p>
    <textarea name="body"><%= post.body %></textarea>

    <button type="submit">Cập nhật</button>
</form>

<a href="/">Quay lại</a>

</body>
</html>