<%- include('layouts/header') %>
<%- include('layouts/navbar') %>

<div class="container">

<div class="card">
    <img src="<%= item.image %>" class="detail-img">

    <h1><%= item.name %></h1>
    <p>Ca sĩ: <%= item.artist %></p>
    <p>Ngày: <%= item.date %></p>

    <% if(item.hot){ %>
        <p class="hot">🔥 HOT</p>
    <% } %>

    <a class="btn" href="/list">Quay lại</a>
</div>

</div>

<%- include('layouts/footer') %>